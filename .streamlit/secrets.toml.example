# Copy this file to .streamlit/secrets.toml and fill in your key.
# On Streamlit Cloud: go to App Settings → Secrets and paste the contents.
#
# Get a FREE CoinGecko Demo API key at: https://www.coingecko.com/en/api/pricing
# (click "Get Started for Free" — no credit card needed)
#
# Without this key, Streamlit Cloud's shared IPs get rate-limited by CoinGecko
# and prices won't load reliably.

COINGECKO_API_KEY = "CG-xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
